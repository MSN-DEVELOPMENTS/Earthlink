[
  {
    "fields": [
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "name": "name",
        "type": "string"
      },
      {
        "options": {
          "source": "name",
          "maxLength": 96
        },
        "validation": [
          {
            "rules": [
              {
                "flag": "custom"
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "name": "slug",
        "type": "slug"
      },
      {
        "description": "e.g. Off-Plan, Resort, Ready",
        "name": "tag",
        "type": "string"
      },
      {
        "name": "location",
        "type": "string"
      },
      {
        "description": "e.g. Apartments, Residences, Villas",
        "name": "type",
        "type": "string"
      },
      {
        "name": "beds",
        "type": "string"
      },
      {
        "name": "area",
        "type": "string"
      },
      {
        "description": "e.g. AED 950K",
        "name": "price",
        "type": "string"
      },
      {
        "name": "ref",
        "type": "string",
        "title": "Reference"
      },
      {
        "name": "permit",
        "type": "string",
        "title": "DLD permit number"
      },
      {
        "options": {
          "hotspot": true
        },
        "name": "image",
        "type": "image"
      },
      {
        "description": "One paragraph per item.",
        "of": [
          {
            "rows": 3,
            "type": "text"
          }
        ],
        "name": "description",
        "type": "array"
      },
      {
        "description": "Lower numbers appear first.",
        "name": "order",
        "type": "number",
        "title": "Sort order"
      }
    ],
    "name": "property",
    "type": "document"
  },
  {
    "fields": [
      {
        "validation": [
          {
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "name": "title",
        "type": "string"
      },
      {
        "options": {
          "source": "title",
          "maxLength": 96
        },
        "validation": [
          {
            "rules": [
              {
                "flag": "custom"
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "level": "error"
          }
        ],
        "description": "The URL of the post, e.g. /blog/your-slug. Click \"Generate\" to build it from the title.",
        "name": "slug",
        "type": "slug"
      },
      {
        "options": {
          "list": [
            "Market Intelligence",
            "Neighbourhood Guides",
            "Investor Notes",
            "Buyer & Tenant Guides"
          ]
        },
        "name": "category",
        "type": "string"
      },
      {
        "rows": 3,
        "validation": [
          {
            "rules": [
              {
                "flag": "max",
                "constraint": 300
              }
            ],
            "level": "error"
          }
        ],
        "description": "Short summary shown on the blog listing card. Also used as the search-result description if no Meta description is set.",
        "name": "excerpt",
        "type": "text"
      },
      {
        "options": {
          "hotspot": true
        },
        "description": "Upload a high-resolution (ideally 2400px+ wide) landscape photo.",
        "fields": [
          {
            "description": "Describe the image for accessibility and SEO.",
            "name": "alt",
            "type": "string",
            "title": "Alt text"
          }
        ],
        "name": "coverImage",
        "type": "image",
        "title": "Cover image"
      },
      {
        "name": "publishedAt",
        "type": "datetime",
        "title": "Published at"
      },
      {
        "description": "The article. Use Normal text for paragraphs, H2 for section headings, and the bullet-list button for lists.",
        "of": [
          {
            "marks": {
              "annotations": [
                {
                  "i18nTitleKey": "inputs.portable-text.annotation.link",
                  "options": {
                    "modal": {
                      "type": "popover"
                    }
                  },
                  "fields": [
                    {
                      "validation": [
                        {
                          "rules": [
                            {
                              "flag": "uri",
                              "constraint": {
                                "options": {
                                  "scheme": [
                                    "/^http$/",
                                    "/^https$/",
                                    "/^tel$/",
                                    "/^mailto$/"
                                  ],
                                  "allowRelative": true,
                                  "relativeOnly": false,
                                  "allowCredentials": false
                                }
                              }
                            }
                          ],
                          "level": "error"
                        }
                      ],
                      "description": "A valid web, email, phone, or relative link.",
                      "name": "href",
                      "type": "url",
                      "title": "Link"
                    }
                  ],
                  "name": "link",
                  "type": "object"
                }
              ],
              "decorators": [
                {
                  "value": "strong",
                  "title": "Strong"
                },
                {
                  "value": "em",
                  "title": "Italic"
                },
                {
                  "value": "code",
                  "title": "Code"
                },
                {
                  "value": "underline",
                  "title": "Underline"
                },
                {
                  "value": "strike-through",
                  "title": "Strike"
                }
              ]
            },
            "lists": [
              {
                "value": "bullet",
                "title": "Bulleted list"
              },
              {
                "value": "number",
                "title": "Numbered list"
              }
            ],
            "styles": [
              {
                "value": "normal",
                "title": "Normal"
              },
              {
                "value": "h1",
                "title": "Heading 1"
              },
              {
                "value": "h2",
                "title": "Heading 2"
              },
              {
                "value": "h3",
                "title": "Heading 3"
              },
              {
                "value": "h4",
                "title": "Heading 4"
              },
              {
                "value": "h5",
                "title": "Heading 5"
              },
              {
                "value": "h6",
                "title": "Heading 6"
              },
              {
                "value": "blockquote",
                "title": "Quote"
              }
            ],
            "of": [],
            "type": "block"
          },
          {
            "options": {
              "hotspot": true
            },
            "type": "image"
          }
        ],
        "name": "body",
        "type": "array"
      },
      {
        "description": "Optional question-and-answer pairs shown at the end of the article.",
        "of": [
          {
            "fields": [
              {
                "name": "question",
                "type": "string"
              },
              {
                "rows": 3,
                "name": "answer",
                "type": "text"
              }
            ],
            "type": "object",
            "name": "faq"
          }
        ],
        "name": "faqs",
        "type": "array",
        "title": "FAQs"
      },
      {
        "description": "Optional. Overrides the browser-tab and search-result title. Aim for under 60 characters.",
        "name": "seoTitle",
        "type": "string",
        "title": "SEO title"
      },
      {
        "rows": 2,
        "description": "Optional. The search-result description. Aim for under 160 characters.",
        "name": "metaDescription",
        "type": "text",
        "title": "Meta description"
      }
    ],
    "name": "post",
    "type": "document",
    "title": "Blog Post"
  },
