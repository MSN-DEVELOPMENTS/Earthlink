# Copy this file to .env.local and fill in your key.
#
# Web3Forms access key — powers the contact + booking forms.
# Get a free key in ~30 seconds at https://web3forms.com (enter the email
# address where you want form submissions delivered, e.g. info@earthlink.ae).
# This key is safe to expose to the browser; it only routes to your email.
NEXT_PUBLIC_WEB3FORMS_KEY=your-access-key-here

# Google Tag Manager container ID — powers analytics/marketing tags.
# Get it at https://tagmanager.google.com (looks like GTM-XXXXXXX). GA4 is
# configured inside the GTM dashboard, so no code change is needed to add it.
# Safe to expose to the browser. Leave unset locally to disable tracking.
NEXT_PUBLIC_GTM_ID=GTM-53SZ8MBV
